{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EV BMS Sensor",
  "type": "object",
  "required": ["type", "title", "description"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["Component", "Sensor", "Actuator", "Controller"],
      "description": "The sensor type"
    },
    "title": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "description": {
      "type": "string",
      "description": "One-line summary of the sensor"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Cross-cutting categorization tags"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime of last meaningful change"
    }
  },
  "additionalProperties": true
}
